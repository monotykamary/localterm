{
  "name": "@monotykamary/localterm-server",
  "version": "2.66.9",
  "description": "PTY-backed HTTP/WebSocket server that powers localterm, built on Hono + node-pty.",
  "keywords": [
    "hono",
    "localterm",
    "node-pty",
    "pty",
    "terminal",
    "websocket"
  ],
  "homepage": "https://github.com/monotykamary/localterm#readme",
  "bugs": {
    "url": "https://github.com/monotykamary/localterm/issues"
  },
  "license": "MIT",
  "author": "Aiden Bai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monotykamary/localterm.git",
    "directory": "packages/server"
  },
  "files": [
    "dist"
  ],
  "os": [
    "darwin",
    "linux"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "import": "./dist/protocol.js"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "import": "./dist/constants.js"
    },
    "./completion": {
      "types": "./dist/completion/index.d.ts",
      "import": "./dist/completion/index.js"
    },
    "./themes": {
      "types": "./dist/terminal-themes.d.ts",
      "import": "./dist/terminal-themes.js"
    },
    "./fonts": {
      "types": "./dist/terminal-fonts.d.ts",
      "import": "./dist/terminal-fonts.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vp test --run --tagsFilter '!integration && !e2e'",
    "test:integration": "vp test --run --tagsFilter integration",
    "test:e2e": "LOCALTERM_E2E_BROWSER=1 vp test --run --tagsFilter e2e",
    "typecheck": "tsc -p tsconfig.build.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "@hono/node-ws": "^1.3.1",
    "@octokit/rest": "^22.0.1",
    "@simplewebauthn/server": "^13.3.2",
    "@xterm/headless": "6.1.0-beta.287",
    "age-encryption": "^0.3.0",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.30",
    "node-pty": "1.1.0",
    "oauth4webapi": "^3.8.6",
    "open": "^11.0.0",
    "picomatch": "^4.0.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/picomatch": "^4.0.3",
    "@types/ws": "^8.18.1",
    "selfsigned": "^5.5.0",
    "typescript": "^7.0.2",
    "vite-plus": "^0.2.4",
    "ws": "^8.21.0"
  },
  "engines": {
    "node": ">=22"
  }
}
