{
  "name": "@monotykamary/localterm-server",
  "version": "2.29.0",
  "description": "PTY-backed HTTP/WebSocket server that powers localterm, built on Hono + node-pty.",
  "keywords": [
    "hono",
    "localterm",
    "node-pty",
    "pty",
    "terminal",
    "websocket"
  ],
  "homepage": "https://github.com/monotykamary/localterm#readme",
  "bugs": {
    "url": "https://github.com/monotykamary/localterm/issues"
  },
  "license": "MIT",
  "author": "Aiden Bai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monotykamary/localterm.git",
    "directory": "packages/server"
  },
  "files": [
    "dist"
  ],
  "os": [
    "darwin",
    "linux"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "import": "./dist/protocol.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vp test --run",
    "typecheck": "tsc -p tsconfig.build.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@hono/node-ws": "^1.1.1",
    "@octokit/rest": "^22.0.1",
    "hono": "^4.6.13",
    "node-pty": "1.1.0",
    "open": "^10.1.0",
    "picomatch": "^4.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/picomatch": "^4.0.3",
    "@types/ws": "^8.18.1",
    "typescript": "^6.0.3",
    "vite-plus": "^0.2.1",
    "ws": "^8.21.0"
  },
  "engines": {
    "node": ">=22"
  }
}
