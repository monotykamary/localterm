{
  "name": "@monotykamary/localterm-monorepo",
  "version": "1.35.4",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/fix-node-pty.mjs",
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "start": "node packages/cli/bin/localterm.mjs restart",
    "stop": "node packages/cli/bin/localterm.mjs stop",
    "cli": "node packages/cli/bin/localterm.mjs",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration --concurrency=2",
    "test:e2e": "turbo run test:e2e --concurrency=2",
    "typecheck": "turbo run typecheck",
    "lint": "node scripts/lint.mjs",
    "lint:fix": "node scripts/lint.mjs --fix",
    "lint:dead": "knip",
    "doctor:react": "react-doctor --yes --no-telemetry --verbose",
    "doctor:react:changed": "react-doctor --yes --no-telemetry --scope lines --base main --include-untracked --no-dead-code --no-supply-chain",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^26.1.1",
    "@voidzero-dev/vite-plus-core": "^0.2.4",
    "knip": "^6.26.0",
    "portless": "^0.15.1",
    "react-doctor": "^0.8.1",
    "turbo": "^2.10.5",
    "typescript": "^7.0.2",
    "vite-plus": "^0.2.4"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@11.6.0"
}
